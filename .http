@host = http://127.0.0.1:9000
@api = {{host}}/api

####################################################
# Public API
####################################################

### API Root
GET {{api}}

###

### Health
GET {{api}}/health

###

### About Page
GET {{api}}/page/about

###

### Home Links
GET {{api}}/data/home-links


