####################################################
# Library Admin
####################################################

@libraryAdminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MTcxLCJlbWFpbCI6ImxpYnJhcnktYWRtaW5AZXhhbXBsZS5jb20iLCJpYXQiOjE3ODQ4MjYyMzQsImV4cCI6MTc4NzQxODIzNH0.aA-2TwowaWZwFh3edyDuA8moCoao9xNAhYHohCPoxHc

###

### Login as Library Admin
POST {{api}}/user/login
Content-Type: application/json

{
  "email": "library-admin@example.com",
  "password": "12345678"
}

###

### Create Library Item
POST {{api}}/admin/library
Authorization: Bearer {{libraryAdminToken}}
Content-Type: application/json

{
  "slug": "test-library-item",
  "title": "Test Library Item",
  "description": "Created from REST Client",
  "type": "HTML",
  "body": "<h1>Hello Taleem</h1>",
  "thumbnail": null,
  "courseId": "course-public"
}

###

### List Library Items
GET {{api}}/admin/library
Authorization: Bearer {{libraryAdminToken}}

###

### Get Library Item
GET {{api}}/admin/library/1
Authorization: Bearer {{libraryAdminToken}}

###

### Update Library Item
PUT {{api}}/admin/library/60
Authorization: Bearer {{libraryAdminToken}}
Content-Type: application/json

{
  "title": "Updated Library Title"
}

###

### Delete Library Item
DELETE {{api}}/admin/library/60
Authorization: Bearer {{libraryAdminToken}}

###

####################################################
# Subscription Admin
####################################################

@subscriptionAdminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MTgxLCJlbWFpbCI6InN1YnNjcmlwdGlvbi1hZG1pbkBleGFtcGxlLmNvbSIsImlhdCI6MTc4NDgyNjgwNCwiZXhwIjoxNzg3NDE4ODA0fQ.8TKcNgdBMrlIgEEoL8IVWN3zAVMUk-rRHhsHOGz-qZ8

