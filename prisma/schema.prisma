generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("student")
  createdAt DateTime @default(now())

  subscriptions  Subscription[]
  communications Communication[]
}

enum ContentType {
  HTML
  JSON
  TEXT
  MARKDOWN
}

model Course {
  id          String  @id
  slug        String  @unique
  title       String
  description String?
  thumbnail   String?

  access String @default("PUBLIC") // PUBLIC | MEMBERS | SUBSCRIPTION

  price Int @default(0)

  library       Library[]
  subscriptions Subscription[]
}

model Library {
  id Int @id @default(autoincrement())

  slug String @unique

  title String

  description String?

  thumbnail String?

  type ContentType

  body String?

  courseId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course         Course          @relation(fields: [courseId], references: [id])
  communications Communication[]

  @@index([slug])
  @@index([courseId])
}

model Subscription {
  id Int @id @default(autoincrement())

  userId   Int
  courseId String

  startsAt DateTime  @default(now())
  endsAt   DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
}

model Communication {
  id Int @id @default(autoincrement())

  userId Int

  libraryId Int

  meta String?

  message String

  authorResponse String?

  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  library Library @relation(fields: [libraryId], references: [id])

  @@index([userId])
  @@index([libraryId])
}
